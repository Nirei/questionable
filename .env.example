# Copy to .env and fill in. .env is gitignored — never commit it.

# ── Database ─────────────────────────────────────────────────────────
PG_USER=questionable
PG_PASSWORD=change-me-with-a-long-random-string
PG_DATABASE=questionable

# ── Phoenix endpoint (Phase 1+) ──────────────────────────────────────
# Generate with:  openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=

# The public hostname behind your nginx (used for URL generation and AP
# actor IDs — once set, do not change without rotating actor identities).
PHX_HOST=questionable.example.com

# Port the BEAM binds inside the container; compose publishes this on
# 127.0.0.1 for the host's nginx to proxy to.
PHX_PORT=4000

# Erlang distribution cookie. Generate with:  openssl rand -hex 32
RELEASE_COOKIE=
